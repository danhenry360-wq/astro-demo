---
interface Props {
  size?: number;
}
const { size = 28 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect width="32" height="32" rx="7" fill="#111111" stroke="#1e1e1e" stroke-width="1"/>
  <path
    d="M8 11 L13 16 L8 21"
    stroke="#00ffe5"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <line
    x1="15" y1="21"
    x2="24" y2="21"
    stroke="#00ffe5"
    stroke-width="2.5"
    stroke-linecap="round"
  />
</svg>
