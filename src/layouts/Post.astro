---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, author } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = new URL(`/posts/${post.id}`, Astro.site).href;
---

<Base {title} {description} {canonicalUrl}>
  <article>
    <!-- Post header -->
    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-xs px-2 py-0.5 rounded-full no-underline font-mono"
            style="background: var(--surface); border: 1px solid var(--border); color: var(--accent);"
          >
            #{tag}
          </a>
        ))}
      </div>

      <h1 class="text-3xl font-bold text-white leading-tight mb-4" style="letter-spacing: -0.03em;">
        {title}
      </h1>

      <p class="text-lg mb-6" style="color: var(--muted);">{description}</p>

      <div class="flex flex-wrap items-center gap-4 text-sm" style="color: var(--muted);">
        <span>{author}</span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {formattedUpdated && (
          <>
            <span>·</span>
            <span>Updated {formattedUpdated}</span>
          </>
        )}
      </div>

      <hr class="mt-8" style="border-color: var(--border);" />
    </header>

    <!-- Post body -->
    <div class="prose">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-8" style="border-top: 1px solid var(--border);">
      <a href="/" style="color: var(--muted); font-size: 0.875rem;">← All posts</a>
    </div>
  </article>
</Base>
